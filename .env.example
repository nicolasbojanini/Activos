# Postgres — control DB (personal ADN, clientes, asignaciones); una sola, compartida.
CONTROL_DATABASE_URL="postgresql://adn:adn@localhost:5432/adn_control?schema=public"
# Placeholder solo para `prisma generate`/`migrate dev` del schema tenant — en runtime
# cada tenant se conecta con su propia URL resuelta desde Cliente.dbName.
TENANT_DATABASE_URL="postgresql://adn:adn@localhost:5432/adn_tenant_demo?schema=public"
# Rol de Postgres compartido para conectarse a CUALQUIER base de datos tenant (no hay
# contraseña por cliente — ver nota en CLAUDE.md).
TENANT_DB_USER="adn"
TENANT_DB_PASSWORD="adn"
# Conexión de mantenimiento para CREATE DATABASE al aprovisionar un cliente nuevo.
POSTGRES_ADMIN_URL="postgresql://adn:adn@localhost:5432/postgres?schema=public"

# JWT
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# MinIO / S3 — usar la IP de red (no "localhost") si vas a probar con fotos desde
# un dispositivo físico: esta URL se incrusta en las URLs prefirmadas de subida y
# en las URLs públicas de galería, que las resuelve el teléfono/navegador, no el servidor.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="adn-activos"
S3_ACCESS_KEY="adn"
S3_SECRET_KEY="adn12345"
S3_FORCE_PATH_STYLE="true"

# Redis (opcional)
REDIS_URL="redis://localhost:6379"

# API
PORT=3000

# Sentry (opcional — vacío = no-op, no se envía nada)
SENTRY_DSN=
